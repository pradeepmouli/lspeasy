{
  "entryPoints": ["packages/core/src/index.ts", "packages/client/src/index.ts", "packages/server/src/index.ts"],
  "tsconfig": "packages/core/tsconfig.json",
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown", "typedoc-plugin-to-skills"],
  "skipErrorChecking": true,
  "includeVersion": true,
  "readme": "none",
  "treatWarningsAsErrors": false,
  "excludePrivate": true,
  "excludeInternal": true,
  "hideGenerator": true,
  "skillsPerPackage": true
}
